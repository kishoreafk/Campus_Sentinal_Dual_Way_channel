{
  "annotations": {"list": []},
  "title": "CCTV Interaction Recognition — Overview",
  "schemaVersion": 39,
  "version": 1,
  "uid": "cctv-overview",
  "panels": [
    {
      "type": "stat",
      "title": "Frames Ingested (total)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(cctv_frames_ingested_total)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Active Tracklets",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(cctv_active_tracklets)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Alerts Generated (total)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(cctv_alerts_generated_total)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Cascade Filter Rate",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "avg(cctv_cascade_filter_rate)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "type": "timeseries",
      "title": "Ingestion Latency",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(cctv_ingestion_latency_seconds_bucket[5m])) by (le))", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Detection Latency",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(cctv_detection_latency_seconds_bucket[5m])) by (le))", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Alert Latency",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(cctv_alert_latency_seconds_bucket[5m])) by (le))", "refId": "A"}]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "5s"
}
