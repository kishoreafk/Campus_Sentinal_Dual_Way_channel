# CCTV Interaction Recognition System — environment overrides
# Copy to .env and adjust as needed. All settings are prefixed with CCTV_.

# General
CCTV_ENVIRONMENT=development
CCTV_LOG_LEVEL=INFO
CCTV_MOCK_MODE=true

# Redis
CCTV_REDIS__HOST=localhost
CCTV_REDIS__PORT=6379
CCTV_REDIS__DB=0

# Postgres
CCTV_POSTGRES__HOST=localhost
CCTV_POSTGRES__PORT=5432
CCTV_POSTGRES__USER=cctv
CCTV_POSTGRES__PASSWORD=cctv
CCTV_POSTGRES__DATABASE=cctv_alerts

# Layer 0 (ingestion)
CCTV_LAYER0__DETECTION_STRIDE=5
CCTV_LAYER0__TARGET_FPS=30
CCTV_LAYER0__FRAME_WIDTH=1280
CCTV_LAYER0__FRAME_HEIGHT=720

# Layer 1 (detection)
CCTV_LAYER1__MAX_BATCH=32
CCTV_LAYER1__BATCH_TIMEOUT_MS=50
CCTV_LAYER1__CONF_THRESHOLD=0.35
CCTV_LAYER1__IOU_THRESHOLD=0.65
CCTV_LAYER1__USE_MOCK=true

# Layer 2 (tracking)
CCTV_LAYER2__TRACK_THRESH=0.5
CCTV_LAYER2__MATCH_THRESH=0.8
CCTV_LAYER2__TRACK_BUFFER=30
CCTV_LAYER2__REID_COSINE_THRESHOLD=0.6
CCTV_LAYER2__SKELETON_BUFFER_LEN=48
CCTV_LAYER2__USE_MOCK=true

# Layer 3 (pair analysis)
CCTV_LAYER3__DISTANCE_RATIO_THRESHOLD=0.8
CCTV_LAYER3__IOU_THRESHOLD=0.15
CCTV_LAYER3__FACE_TO_FACE_DOT_THRESHOLD=-0.3
CCTV_LAYER3__SUSTAINED_PROXIMITY_FRAMES=15
CCTV_LAYER3__MIN_KEYPOINT_CONFIDENCE=0.5

# Layer 4A (interaction)
CCTV_LAYER4A__CASCADE_SCORE_THRESHOLD=0.4
CCTV_LAYER4A__FUSION_POSE_WEIGHT=0.6
CCTV_LAYER4A__FUSION_RGB_WEIGHT=0.4
CCTV_LAYER4A__USE_MOCK=true

# Layer 4B (individual)
CCTV_LAYER4B__CONF_THRESHOLD=0.6
CCTV_LAYER4B__USE_MOCK=true

# Layer 5 (post-process)
CCTV_LAYER5__EMA_ALPHA=0.7
CCTV_LAYER5__DEDUP_WINDOW_S=3.0

# Layer 6 (alerts)
CCTV_LAYER6__CLIP_DURATION_S=10
CCTV_LAYER6__CLIP_STORAGE_PATH=data/clips
CCTV_LAYER6__HOT_RETENTION_DAYS=30

# Layer 7 (monitoring)
CCTV_LAYER7__API_PORT=8000
